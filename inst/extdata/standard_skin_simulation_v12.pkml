          <OutputFormulas>
            <KeyValue>
              <Formula id="F1byKp-ogEK5lsdaK8amag" name="PARAM_K_rbc" formula="(f_water_rbc + f_lipids_rbc * 10^LogMA + f_proteins_rbc * KProt)*fu">
