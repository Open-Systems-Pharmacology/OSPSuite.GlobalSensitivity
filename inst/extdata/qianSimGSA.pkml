            <KeyValue>
              <Formula id="v15poQEdlEidwLPs_1smhg" name="PARAM_K_cell_pls_Berezhkovskiy" formula="(10^LogP * (V_nlt + 0.3 * V_pht) +  0.7 * V_pht + V_wt / fu_t) / (10^LogP * (V_nlp + 0.3 * V_php) +  0.7 * V_php + V_wp / fu)">
