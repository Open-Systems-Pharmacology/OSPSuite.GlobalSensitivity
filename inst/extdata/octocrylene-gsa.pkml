      <AllCalculationMethods>
        <CoreCalculationMethod id="T9jyVONmLUyyHKvdaM8QtQ" name="Cellular partition coefficient method - Berezhkovskiy" icon="CoreCalculationMethod" bbVersion="0" category="DistributionCellular">
          <Creation createdAt="5249970292011938391" createdBy="ahamadeh" creationMode="New" origin="Other" />
          <OutputFormulas>
            <KeyValue>
              <Formula id="m0rhruY2JkmLll6O96qEsQ" name="PARAM_K_rbc" formula="(f_water_rbc + f_lipids_rbc * 10^LogMA + f_proteins_rbc * KProt)*fu">
                <Paths>
                  <Path path="0" as="1" dim="2" />
                  <Path path="3" as="4" dim="5" />
                  <Path path="6" as="7" />
                  <Path path="8" as="9" />
                  <Path path="10" as="11" />
                  <Path path="12" as="13" />
                </Paths>
              </Formula>
              <ParameterDescriptor parameterName="Partition coefficient (blood cells/plasma)">
                <ContainerCriteria operator="And">
                  <DescriptorConditions>
                    <MatchTagCondition tag="RootContainer" />
                  </DescriptorConditions>
                </ContainerCriteria>
              </ParameterDescriptor>
            </KeyValue>
            <KeyValue>
              <Formula id="d0mGG4zHbE2caMT-5izyEQ" name="PARAM_K_cell_pls_Berezhkovskiy" formula="(10^LogP * (V_nlt + 0.3 * V_pht) +  0.7 * V_pht + V_wt / fu_t) / (10^LogP * (V_nlp + 0.3 * V_php) +  0.7 * V_php + V_wp / fu)">
                <Paths>
                  <Path path="14" as="15" dim="2" />
                  <Path path="0" as="1" dim="2" />
                  <Path path="3" as="16" dim="5" />
                  <Path path="17" as="18" />
                  <Path path="19" as="20" />
                  <Path path="21" as="22" />
                  <Path path="23" as="24" />
                  <Path path="25" as="26" />
                  <Path path="27" as="28" />
                </Paths>
              </Formula>
              <ParameterDescriptor parameterName="Partition coefficient (intracellular/plasma)">
                <ContainerCriteria operator="And">
                  <DescriptorConditions>
                    <NotMatchTagCondition tag="Fat_int_Fat_cell" />
                    <MatchTagCondition tag="Neighborhood: Interstitial / Intracellular" />
                  </DescriptorConditions>
                </ContainerCriteria>
              </ParameterDescriptor>
            </KeyValue>
            <KeyValue>
              <Formula id="510Prg3Cf0OZFLnc6Ci1hA" name="PARAM_K_cell_pls_fat" formula="(10^LogP_ow * (V_nlt + 0.3 * V_pht) +  0.7 * V_pht + V_wt / fu_t) / (10^LogP_ow * (V_nlp + 0.3 * V_php) +  0.7 * V_php + V_wp / fu)">
                <Paths>
                  <Path path="14" as="15" dim="2" />
                  <Path path="0" as="1" dim="2" />
                  <Path path="29" as="30" dim="5" />
                  <Path path="17" as="18" />
                  <Path path="19" as="20" />
                  <Path path="21" as="22" />
                  <Path path="23" as="24" />
                  <Path path="25" as="26" />
                  <Path path="27" as="28" />
                </Paths>
              </Formula>
              <ParameterDescriptor parameterName="Partition coefficient (intracellular/plasma)">
                <ContainerCriteria operator="And">
                  <DescriptorConditions>
                    <MatchTagCondition tag="Fat_int_Fat_cell" />
                    <MatchTagCondition tag="Neighborhood: Interstitial / Intracellular" />
                  </DescriptorConditions>
                </ContainerCriteria>
              </ParameterDescriptor>
            </KeyValue>
