      <AllCalculationMethods>
        <CoreCalculationMethod id="T9jyVONmLUyyHKvdaM8QtQ" name="Cellular partition coefficient method - Berezhkovskiy" icon="CoreCalculationMethod" bbVersion="0" category="DistributionCellular">
          <Creation createdAt="5249970292011938391" createdBy="ahamadeh" creationMode="New" origin="Other" />
          <OutputFormulas>
            <KeyValue>
              <Formula id="m0rhruY2JkmLll6O96qEsQ" name="PARAM_K_rbc" formula="(f_water_rbc + f_lipids_rbc * 10^LogMA + f_proteins_rbc * KProt)*fu">
                <Paths>
                  <Path path="0" as="1" dim="2" />
                  <Path path="3" as="4" dim="5" />
                  <Path path="6" as="7" />
                  <Path path="8" as="9" />
                  <Path path="10" as="11" />
                  <Path path="12" as="13" />
