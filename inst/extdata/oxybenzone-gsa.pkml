              </Formula>
              <ParameterDescriptor parameterName="Partition coefficient (blood cells/plasma)">
                <ContainerCriteria operator="And">
                  <DescriptorConditions>
                    <MatchTagCondition tag="RootContainer" />
                  </DescriptorConditions>
                </ContainerCriteria>
              </ParameterDescriptor>
            </KeyValue>
            <KeyValue>
              <Formula id="d0mGG4zHbE2caMT-5izyEQ" name="PARAM_K_cell_pls_Berezhkovskiy" formula="(10^LogP * (V_nlt + 0.3 * V_pht) +  0.7 * V_pht + V_wt / fu_t) / (10^LogP * (V_nlp + 0.3 * V_php) +  0.7 * V_php + V_wp / fu)">
